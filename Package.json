{
  "name": "trustos",
  "version": "1.0.0",
  "description": "The Operating System for Autonomous AI Entities",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "automate": "node scripts/trustos-automation.js",
    "scheduler": "node scripts/scheduler.js",
    "autostart": "pm2 start scripts/scheduler.js --name trustos-scheduler",
    "build": "tsc",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write 'src/**/*.{js,ts}'"
  },
  "keywords": [
    "ai",
    "autonomous-entities",
    "orchestration",
    "identity-management",
    "future-technology",
    "trust-corp"
  ],
  "author": "Eli Trust <eli.trust@trustcorp.ai>",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "joi": "^17.9.2",
    "winston": "^3.9.0",
    "redis": "^4.6.4",
    "node-cron": "^3.0.2",
    "axios": "^1.3.6"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "eslint": "^8.38.0",
    "prettier": "^2.8.8"
  }
}
